# ── Docker Compose Configuration ──

# Ports
FRONTEND_BIND_HOST=127.0.0.1
FRONTEND_HOST_PORT=8081
BACKEND_BIND_HOST=127.0.0.1
BACKEND_HOST_PORT=3002

# Frontend build args
VITE_APP_BASE_PATH=/
VITE_API_BASE_URL=http://localhost:3002

# Backend
JWT_SECRET=tresorpay-stats-secret-changer-en-production
JWT_EXPIRES_IN=8h
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=Admin@2026!
SUPER_ADMIN_FULLNAME=Super Administrateur

# Payment Platform (source de synchronisation)
PP_REMOTE_API_URL=http://host.docker.internal:3005
PP_REMOTE_USERNAME=
PP_REMOTE_PASSWORD=

# Synchronisation
SYNC_INTERVAL_MS=600000
SYNC_ENABLED=true
