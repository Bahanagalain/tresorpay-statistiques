# ──── Serveur ────
PORT=3002
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5175,http://localhost:4173,http://localhost:3000,http://localhost,https://stats.devinst.tresorpublic.cm,https://stats-api.devinst.tresorpublic.cm

# ──── PostgreSQL ────
DATABASE_URL=postgresql://postgres:postgres@localhost:5436/tresorpay_statistiques

# ──── JWT ────
JWT_SECRET=tresorpay-stats-secret-changer-en-production
JWT_EXPIRES_IN=8h

# ──── Super Admin (cree au seed) ────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=Admin@2026!
SUPER_ADMIN_FULLNAME=Super Administrateur

# ──── API Payment Platform (source de synchronisation) ────
PP_REMOTE_API_URL=http://localhost:3005
PP_REMOTE_USERNAME=stats-sync-user
PP_REMOTE_PASSWORD=
PP_AUTH_ENDPOINT=/auth/login

# ──── Synchronisation automatique (Pull) ────
# Intervalle en ms — 600000 = 10 min
SYNC_INTERVAL_MS=600000
SYNC_ENABLED=true

# ──── SMTP / Email ────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=TresorPay Statistiques <noreply@example.com>
