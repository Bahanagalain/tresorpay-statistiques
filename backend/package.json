{
  "name": "tresorpay-statistiques-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend TresorPay Statistiques — Fastify + Prisma + PostgreSQL + Swagger",
  "main": "src/app.js",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate"
  },
  "prisma": {
    "seed": "node src/seeds/seed.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "nodemailer": "^8.0.5",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
